BLTCY_API_KEY=replace-with-your-api-key
BLTCY_BASE_URL=https://api.bltcy.ai
BLTCY_IMAGE_MODEL=gpt-image-2
BLTCY_IMAGE_SIZE=1024x1536
BLTCY_FALLBACK_TO_MOCK=true

# Text model for conversation, prompt optimization, and RAG fusion
DEEPSEEK_API_KEY=replace-with-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING=disabled
DEEPSEEK_GENERATION_PROMPTING=true

# Auth providers
